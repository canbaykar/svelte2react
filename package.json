{
  "name": "@baykar/svelte2react",
  "version": "0.0.0-development",
  "description": "Use Svelte components in React.",
  "private": false,
  "keywords": [
    "svelte",
    "svelte5",
    "react",
    "svelte-component",
    "react-component",
    "svelte-to-react",
    "cross-framework",
    "svelte2react"
  ],
  "license": "0BSD",
  "author": "Togan Can Baykar",
  "type": "module",
  "scripts": {
    "build": "svelte-package -i ./src -o ./dist",
    "release": "changeset publish",
    "preinstall": "npx only-allow pnpm"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@sveltejs/package": "^2.5.7",
    "@types/node": "^25.6.2",
    "@types/react": "^16.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "svelte": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canbaykar/svelte2react.git"
  }
}

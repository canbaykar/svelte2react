{
  "name": "@baykar/svelte2react",
  "version": "1.0.0",
  "description": "Use Svelte components in React.",
  "private": false,
  "keywords": [
    "rollup",
    "plugin",
    "rollup-plugin"
  ],
  "license": "0BSD",
  "author": "Togan Can Baykar",
  "type": "module",
  "scripts": {
    "build": "svelte-package -i ./src -o ./dist"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@types/node": "^25.6.2",
    "@types/react": "^16.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "svelte": "^5.0.0"
  }
}

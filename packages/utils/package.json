{
	"name": "utils",
	"version": "0.0.0",
	"description": "Utilities for other packages for svelte2react.",
	"private": true,
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"watch": "tsc --watch"
	},
	"files": [
		"dist",
		"README.md"
	],
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"engines": {
		"node": ">=24"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11",
			"onFail": "error"
		}
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/canbaykar/svelte2react.git"
	},
	"dependencies": {
		"scule": "^1.3.0"
	}
}
